{
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": false
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/swift-format.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
