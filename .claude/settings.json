{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/swift-format.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(make check)",
      "Bash(make test-unit)",
      "Bash(make test-unit-agent)",
      "Bash(make test-single *)",
      "Bash(make test-single-agent *)",
      "Bash(make test-failures)",
      "Bash(make format)",
      "Bash(make help)",
      "Bash(./gradlew ktlintCheck)",
      "Bash(./gradlew ktlintFormat)",
      "Bash(./gradlew detekt)",
      "Bash(./gradlew lint)",
      "Bash(./gradlew testDebugUnitTest)",
      "Bash(./gradlew assembleDebug)",
      "Bash(git -C * status)",
      "Bash(git -C * status *)",
      "Bash(git -C * log)",
      "Bash(git -C * log *)",
      "Bash(git -C * diff)",
      "Bash(git -C * diff *)",
      "Bash(git -C * show *)",
      "Bash(git -C * branch)",
      "Bash(git -C * branch *)",
      "Bash(git -C * blame *)"
    ]
  }
}
